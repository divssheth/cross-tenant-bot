# =============================================================================
# Cross-Tenant Teams Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# UAMI Configuration (Bot Framework Authentication)
# -----------------------------------------------------------------------------
# User-Assigned Managed Identity for secure, secret-free bot authentication

AZURE_CLIENT_ID=your-uami-client-id
MICROSOFT_APP_ID=your-uami-client-id
AZURE_TENANT_ID=your-home-tenant-id
MICROSOFT_APP_TYPE=SingleTenant

# -----------------------------------------------------------------------------
# Graph API Configuration (RSC Permissions)
# -----------------------------------------------------------------------------
# Multi-tenant app registration for cross-tenant Graph API access
# Set ENABLE_RSC=true to enable RSC features (channel message reading)

ENABLE_RSC=false
GRAPH_APP_ID=your-multi-tenant-app-client-id
KEY_VAULT_NAME=your-keyvault-name
GRAPH_CLIENT_SECRET_NAME=graph-client-secret

# For LOCAL DEVELOPMENT ONLY (not recommended for production):
# GRAPH_CLIENT_SECRET=your-client-secret-value

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

PORT=3978

# -----------------------------------------------------------------------------
# Optional: Conversation Context Settings
# -----------------------------------------------------------------------------

MAX_CONTEXT_MESSAGES=20
MAX_GRAPH_MESSAGES=20

# -----------------------------------------------------------------------------
# Azure AI Foundry Configuration (for AI-powered responses)
# -----------------------------------------------------------------------------
# Project endpoint from Azure AI Foundry (formerly Azure AI Studio)
# Format: https://<your-resource>.services.ai.azure.com/api/projects/<project-name>

AZURE_AI_PROJECT_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/api/projects/your-project

# Model deployment name (default: gpt-4o)
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# AI response settings (optional)
AI_MAX_TOKENS=1000
AI_AGENT_NAME=CrossTenantAssistant

# -----------------------------------------------------------------------------
# Teams App Configuration
# -----------------------------------------------------------------------------
# Container App Domain (without https://)
CONTAINER_APP_DOMAIN=your-container-app.azurecontainerapps.io
