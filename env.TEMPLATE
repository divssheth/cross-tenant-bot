# =============================================================================
# Cross-Tenant Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Local Development
# -----------------------------------------------------------------------------
# Set to true to skip UAMI auth (allows agentsplayground/emulator to connect)
LOCAL_DEBUG=false

# Set to true to send traces to AI Toolkit (port 4317) instead of App Insights
# Requires LOCAL_DEBUG=true; ignored with a warning if LOCAL_DEBUG=false
LOCAL_TRACING=false

# Server port (default: 3978)
PORT=3978

# -----------------------------------------------------------------------------
# Azure Identity (Bot Framework Authentication)
# -----------------------------------------------------------------------------
# User-Assigned Managed Identity for secure, secret-free bot authentication
# Note: For UAMI bots, AZURE_CLIENT_ID is used for both bot auth and managed identity

AZURE_CLIENT_ID=your-uami-client-id
AZURE_TENANT_ID=your-azure-tenant-id
MicrosoftAppType=UserAssignedMsi

# -----------------------------------------------------------------------------
# Microsoft Graph API (RSC Permissions)
# -----------------------------------------------------------------------------
# App registration for Graph API calls (client credentials flow)
# GRAPH_TENANT_ID is the TARGET tenant for Graph API calls (customer tenant)
# This can differ from AZURE_TENANT_ID in cross-tenant scenarios

GRAPH_TENANT_ID=your-target-tenant-id
GRAPH_APP_ID=your-graph-app-client-id

# Key Vault for retrieving client secret (UAMI has access)
KEY_VAULT_NAME=your-keyvault-name
GRAPH_CLIENT_SECRET_NAME=graph-client-secret

# LOCAL DEV ONLY - Use Key Vault in production
# GRAPH_CLIENT_SECRET=your-client-secret-value

# Enable RSC (Resource-Specific Consent) features
ENABLE_RSC=false

# -----------------------------------------------------------------------------
# Azure AI Foundry (Agent Framework)
# -----------------------------------------------------------------------------
# Azure OpenAI endpoint (format: https://<resource>.openai.azure.com/)
AZURE_AI_ENDPOINT=https://your-resource.openai.azure.com/

# Model deployment name (e.g., gpt-4o, gpt-4.1)
AZURE_AI_MODEL=gpt-4o

# Agent name (alphanumeric + hyphens, max 63 chars)
AZURE_AI_AGENT_NAME=teams-bot-agent

# Deployed Foundry agent ID for license/M365 knowledge (name:version format)
AZURE_AI_LICENSE_AGENT_ID=unified-knowledge-agent-1:7

# Max tokens for responses
AZURE_AI_MAX_TOKENS=1000

# -----------------------------------------------------------------------------
# Azure AI Foundry Project (for Evaluation Portal)
# -----------------------------------------------------------------------------
# Required for --log-to-foundry to show evaluations in Foundry Portal
# Format: https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=

# -----------------------------------------------------------------------------
# Azure AI Search (Knowledge Base)
# -----------------------------------------------------------------------------
# Azure AI Search endpoint for Foundry IQ knowledge base
AZURE_SEARCH_ENDPOINT=

# Knowledge base/index name in Azure AI Search
AZURE_SEARCH_INDEX_NAME=

# -----------------------------------------------------------------------------
# Telemetry (Application Insights)
# -----------------------------------------------------------------------------
# Connection string from Azure Portal > Application Insights > Overview
APPLICATIONINSIGHTS_CONNECTION_STRING=

# WARNING: Do NOT set AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=true
# It conflicts with Agent Framework's built-in instrumentation and causes
# NonRecordingSpan attribute errors at runtime.

# -----------------------------------------------------------------------------
# Conversation Settings
# -----------------------------------------------------------------------------
# Max messages to store in conversation state (1:1 and group chats)
MAX_CONTEXT_MESSAGES=20

# Max messages to retrieve from Graph API (channel history)
MAX_GRAPH_MESSAGES=50

# -----------------------------------------------------------------------------
# Deployment (Azure Container Apps)
# -----------------------------------------------------------------------------
CONTAINER_APP_DOMAIN=your-app.azurecontainerapps.io
